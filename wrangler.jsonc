{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pdf-kit",
  "main": "src/worker.ts",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": ["nodejs_compat"]
}
